# Dependencies
node_modules/

# Build output — regenerated by Vite, never committed. GitHub Pages builds
# from source in Actions, not from a tracked dist/ branch.
dist/

# Test coverage reports
coverage/

# Local environment files
.env
.env.*
!.env.example

# Editor / IDE
.idea/
.vscode/
*.iml
*.swp
*.swo

# OS scratch files
.DS_Store
Thumbs.db
desktop.ini

# Temporary dev scratch — tmp-test.jpg is a leftover from measurement work.
tmp-*
*.tmp

# Session transcripts / notes not meant to ship
claude.txt

# Claude Code per-machine settings (MCP tokens, local permissions)
.claude/

# `.nojekyll` only belongs inside `dist/` at deploy time — the workflow
# writes it there. A stray root-level file was an earlier mistake.
/.nojekyll

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python extraction script scratch
scripts/__pycache__/
*.pyc
